# Get channel ID: right-click #update-vibe → View channel details → copy ID (starts with C)
SLACK_CHANNEL_ID=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=


# Application
APP_NAME=python-test
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (default in-memory SQLite)
DATABASE_URL=sqlite+aiosqlite:///:memory:

# JWT (use strong secret in production, min 32 chars)
JWT_SECRET_KEY=change-me-in-production-use-env
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
